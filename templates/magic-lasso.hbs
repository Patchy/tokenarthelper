<div class="magic-lasso">
    <div class="tokenarthelper description">
    <section class="window-content">
        <h1>{{localize "tokenarthelper.MagicLasso.title"}}</h1>
        <p>{{localize "tokenarthelper.MagicLasso.description"}}</p>
        <hr>
        <div id="magic-lasso-buttons">
            <div display="flex">
                <div style="overflow: auto">
                    <div style="float: left; margin-right: 10px;">Blur radius: </div>
                    <input id="arteditor-blur-radius" type="text"/>
                    <div id="arteditor-threshold"></div>
                </div>
            </div>
            <hr>
            <div class="buttons">
                <button data-action="delete" class="tokenarthelper ui button" title="{{localize "tokenarthelper.MagicLasso.transparent"}}"><i class="fas fa-eye-slash"></i> {{localize "tokenarthelper.label.Transparent"}}</button>
                <button id="lasso-fill" data-action="fill" class="tokenarthelper ui button" title="{{localize "tokenarthelper.MagicLasso.fill"}}" disabled><i class="fas fa-fill-drip"></i> {{localize "tokenarthelper.label.Fill"}}</button>
                <div class="tokenarthelper">
                    <input id="magic-lasso-color-selector" type="color" value="#00000FF">
                    <div id="magic-lasso-color-selector-proxy" title="{{localize "tokenarthelper.label.FillColor"}}" class="color-picker transparent"></div>
                </div>
            </div>
            <hr>
            <div class="buttons">
                <button data-action="ok" class="tokenarthelper ui button" title="{{localize "tokenarthelper.MagicLasso.save"}}"><i class="fas fa-check"></i> {{localize "tokenarthelper.label.Apply"}}</button>
                <button data-action="cancel" class="tokenarthelper ui button" title="{{localize "tokenarthelper.MagicLasso.close"}}"><i class="fas fa-times"></i> {{localize "tokenarthelper.label.Cancel"}}</button>
            </div>
        </div>
    </section>
    </div>
</div>
